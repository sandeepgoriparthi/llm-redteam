# Target model config
TARGET_PROVIDER=openai          # openai | ollama | custom
TARGET_MODEL=gpt-4o
TARGET_ENDPOINT=                # leave blank for openai default; set for ollama/custom
OPENAI_API_KEY=

# Ollama (if TARGET_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434

# Analyst LLM (used by suggest_patch node -- can differ from target)
ANALYST_PROVIDER=openai
ANALYST_MODEL=gpt-4o
ANALYST_API_KEY=

# Paths
DB_PATH=data/redteam.db
REPORTS_DIR=reports/

# Garak
GARAK_PROBE_CATEGORIES=dan,gcg,encoding,promptinject
GARAK_TIMEOUT=300
